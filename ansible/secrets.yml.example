# ansible/secrets.yml
#
# This file is NEVER committed to git. Copy this example and fill in real values:
#
#   cp secrets.yml.example secrets.yml
#   # edit secrets.yml
#
# Optional: encrypt with ansible-vault for additional local protection:
#   ansible-vault encrypt secrets.yml
#   # ansible-playbook then needs: --ask-vault-pass
#
# All values are passed to Ansible via:
#   ./scripts/provision.sh
#   — or manually —
#   ansible-playbook site.yml --extra-vars "@secrets.yml"
#
# ─── How to generate strong secrets ──────────────────────────────────────────
#   openssl rand -hex 32    → 64-char hex string (for passkeys, tokens)
#   openssl rand -base64 32 → 44-char base64 string (for passwords)
#   cat ~/.ssh/id_ed25519.pub → SSH public key
# ─────────────────────────────────────────────────────────────────────────────

# ── SSH ──────────────────────────────────────────────────────────────────────
# Public key to inject into the 'deploy' user's authorized_keys on the server.
# This is NOT secret (public key), but it lives here so CI/CD can supply it
# without requiring a local file at ~/.ssh/id_ed25519.pub.
#
# Get it with: cat ~/.ssh/id_ed25519.pub
deploy_ssh_public_key: "ssh-ed25519 AAAAC3... your_email@example.com"

# ── deploy user ───────────────────────────────────────────────────────────────
# Password for the 'deploy' system user (used for sudo, not SSH login).
# SSH login is key-only; this is only needed if you sudo with a password prompt.
# Generate: openssl rand -base64 32
deploy_password: "CHANGE_ME"

# ── Komodo ────────────────────────────────────────────────────────────────────
# PostgreSQL password for FerretDB's dedicated postgres-documentdb instance.
# This is NOT the shared infra postgres — FerretDB requires its own patched image.
# Generate: openssl rand -hex 32
ferretdb_postgres_password: "CHANGE_ME_openssl_rand_hex_32"

# JWT signing secret for Komodo Core.
# Generate: openssl rand -hex 32
komodo_jwt_secret: "CHANGE_ME_openssl_rand_hex_32"

# Password for the Komodo admin account (username is set in group_vars/all.yml).
# This is the password you log in to https://komodo.fewa.app with.
# Generate: openssl rand -base64 32
komodo_password: "CHANGE_ME"

# REQUIRED — Komodo API passkey.
# Used by API clients and CLI tools to authenticate to Komodo.
# Must be a long random string. If left empty, Komodo API will be open.
# Generate: openssl rand -hex 32
komodo_passkey: "CHANGE_ME_openssl_rand_hex_32"

# REQUIRED — Komodo webhook secret.
# Used to validate incoming webhooks (e.g. from GitHub).
# Must be a long random string.
# Generate: openssl rand -hex 32
komodo_webhook_secret: "CHANGE_ME_openssl_rand_hex_32"

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Cloudflare API token used by Caddy for DNS-01 TLS challenge (ACME).
# This token is what allows Caddy to get HTTPS certificates without opening port 80.
#
# How to create it:
#   1. Go to https://dash.cloudflare.com/profile/api-tokens
#   2. Click "Create Token"
#   3. Use template "Edit zone DNS"
#   4. Under "Zone Resources", select: fewa.app (specific zone)
#   5. Click "Continue to summary" → "Create Token"
#   6. Copy the token value below (it is only shown once)
#
cloudflare_api_token: "CHANGE_ME"

# ── Shared Infra Postgres ─────────────────────────────────────────────────────
# Root password for the shared postgres:16 instance (used by infra health checks).
# Generate: openssl rand -hex 32
shared_postgres_password: "CHANGE_ME_openssl_rand_hex_32"

# Per-app database user passwords for the shared Postgres instance.
# Each app gets its own user and database for isolation.
# Generate each: openssl rand -hex 32
shared_postgres_sure_password: "CHANGE_ME_openssl_rand_hex_32"
shared_postgres_gitea_password: "CHANGE_ME_openssl_rand_hex_32"
shared_postgres_nocodb_password: "CHANGE_ME_openssl_rand_hex_32"

# ── Gitea ─────────────────────────────────────────────────────────────────────
# Internal secret key used by Gitea to sign tokens and cookies.
# Generate: openssl rand -hex 32
gitea_secret_key: "CHANGE_ME_openssl_rand_hex_32"

# ── Sure ──────────────────────────────────────────────────────────────────────
# Secret key base for Rails encryption (sessions, cookies, etc).
# Generate: openssl rand -hex 64
sure_secret_key_base: "CHANGE_ME_openssl_rand_hex_64"

# PostgreSQL password for Sure's dedicated database user.
# Generate: openssl rand -base64 32

# OpenAI API key for Sure's AI assistant feature.
# Get it from: https://platform.openai.com/api-keys
openai_access_token: "CHANGE_ME"

# ── NocoDB ────────────────────────────────────────────────────────────────────
# JWT signing secret for NocoDB authentication.
# Generate: openssl rand -hex 32
nocodb_jwt_secret: "CHANGE_ME_openssl_rand_hex_32"

# ── Databasus ─────────────────────────────────────────────────────────────────
# Internal secret key for Databasus session encryption.
# Generate: openssl rand -hex 32
databasus_secret_key: "CHANGE_ME_openssl_rand_hex_32"

# Cloudflare R2 credentials for backup storage.
# Create an R2 API token at: https://dash.cloudflare.com/?to=/:account/r2/api-tokens
r2_access_key_id: "CHANGE_ME"
r2_secret_access_key: "CHANGE_ME"

# ── n8n ───────────────────────────────────────────────────────────────────────
# PostgreSQL password for n8n's dedicated database user.
# Generate: openssl rand -hex 32
shared_postgres_n8n_password: "CHANGE_ME_openssl_rand_hex_32"

# n8n encryption key — used to encrypt credentials stored in the DB.
# Generate: openssl rand -hex 32
# NOTE: Store this in Komodo Variables (N8N_ENCRYPTION_KEY), not here.
#       If lost, all saved credentials in n8n become unrecoverable.
# n8n_encryption_key: "CHANGE_ME_openssl_rand_hex_32"