# hosts.ini.example — format reference for ansible/inventory/hosts.ini
# The actual hosts.ini is generated by scripts/provision.sh and is gitignored.
# Do not edit hosts.ini manually.
#
# Copy this file and replace <IP> with your server's public IP for standalone use:
#   cp hosts.ini.example hosts.ini

[fewaapp]
<IP> ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_ed25519 ansible_ssh_port=22
