---
# Managed by Ansible — do not edit by hand
# NocoDB — no-code database platform

networks:
  infra_net:
    external: true

services:
  nocodb:
    image: "{{ nocodb_image }}"
    restart: unless-stopped
    env_file: .env
    ports:
      - "127.0.0.1:{{ nocodb_port }}:8080"
    volumes:
      - "{{ nocodb_dir }}/data:/usr/app/data"
    networks:
      - infra_net
    mem_limit: 1g
