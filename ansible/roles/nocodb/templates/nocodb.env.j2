# ── NocoDB database (shared infra Postgres) ───────────────────────────────────
# Format: pg://<host>:<port>?u=<user>&p=<password>&d=<database>
NC_DB=pg://postgres:5432?u=nocodb_user&p={{ shared_postgres_nocodb_password }}&d=nocodb

# ── NocoDB application ────────────────────────────────────────────────────────
NC_AUTH_JWT_SECRET={{ nocodb_jwt_secret }}
NC_PUBLIC_URL=https://{{ nocodb_subdomain }}

# ── NocoDB misc ───────────────────────────────────────────────────────────────
NC_DISABLE_TELE=true
