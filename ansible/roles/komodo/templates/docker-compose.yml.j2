services:
  mongo:
    image: {{ mongo_image }}
    restart: unless-stopped
    command: --wiredTigerCacheSizeGB 1
    volumes:
      - {{ komodo_dir }}/mongodb:/data/db
    environment:
      MONGO_INITDB_ROOT_USERNAME: ${KOMODO_DB_USERNAME}
      MONGO_INITDB_ROOT_PASSWORD: ${KOMODO_DB_PASSWORD}
    networks:
      - komodo-net
    healthcheck:
      test: ["CMD", "mongosh", "--quiet", "--eval", "db.adminCommand('ping').ok"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 2g

  komodo:
    image: {{ komodo_image }}
    restart: unless-stopped
    depends_on:
      mongo:
        condition: service_healthy
    ports:
      - "127.0.0.1:{{ komodo_port }}:{{ komodo_port }}"
    environment:
      KOMODO_DATABASE_ADDRESS: mongo:27017
      KOMODO_DATABASE_USERNAME: ${KOMODO_DB_USERNAME}
      KOMODO_DATABASE_PASSWORD: ${KOMODO_DB_PASSWORD}
      KOMODO_HOST: ${KOMODO_HOST}
      KOMODO_PORT: ${KOMODO_PORT}
      KOMODO_PASSKEY: ${KOMODO_PASSKEY}
      KOMODO_WEBHOOK_SECRET: ${KOMODO_WEBHOOK_SECRET}
      KOMODO_LOG_LEVEL: ${KOMODO_LOG_LEVEL}
      KOMODO_LOCAL_AUTH: "true"
      KOMODO_INIT_ADMIN_USERNAME: ${KOMODO_INIT_ADMIN_USERNAME}
      KOMODO_INIT_ADMIN_PASSWORD: ${KOMODO_INIT_ADMIN_PASSWORD}
    volumes:
      - {{ komodo_dir }}/data:/etc/komodo
    networks:
      - komodo-net
    deploy:
      resources:
        limits:
          memory: 1g

networks:
  komodo-net:
    driver: bridge
