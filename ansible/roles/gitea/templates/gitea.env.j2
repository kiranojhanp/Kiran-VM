# ── Gitea database (shared infra Postgres) ────────────────────────────────────
GITEA__database__DB_TYPE=postgres
GITEA__database__HOST=postgres:5432
GITEA__database__NAME=gitea
GITEA__database__USER=gitea_user
GITEA__database__PASSWD={{ shared_postgres_gitea_password }}
GITEA__database__SSL_MODE=disable

# ── Gitea server ─────────────────────────────────────────────────────────────
GITEA__server__DOMAIN={{ gitea_subdomain }}
GITEA__server__ROOT_URL=https://{{ gitea_subdomain }}
GITEA__server__HTTP_PORT=3000
GITEA__server__SSH_DOMAIN={{ gitea_subdomain }}
GITEA__server__SSH_PORT={{ gitea_ssh_port }}
GITEA__server__SSH_LISTEN_PORT=2222
GITEA__server__DISABLE_SSH=false
GITEA__server__ENABLE_PPROF=false

# ── Gitea security ────────────────────────────────────────────────────────────
GITEA__security__SECRET_KEY={{ gitea_secret_key }}
GITEA__security__INSTALL_LOCK=false

# ── Gitea service ─────────────────────────────────────────────────────────────
GITEA__service__DISABLE_REGISTRATION=false
GITEA__service__REQUIRE_SIGNIN_VIEW=false

# ── Gitea logging ─────────────────────────────────────────────────────────────
GITEA__log__LEVEL=info
