# AIOStreams Environment Variables
# Copy this to .env and fill in required values
#
# IMPORTANT: Hosting Warnings
# - HuggingFace/Render free tiers are NOT suitable for media streaming
# - Free tiers will get YOU KICKED due to bandwidth usage
# - Use a VPS (Oracle, Hetzner, etc.) or home server instead
# - HTTPS is MANDATORY (Stremio only connects to https endpoints)

# ==============================================================================
# REQUIRED
# ==============================================================================

# Public URL of your instance (required)
BASE_URL=https://aiostreams.fewa.app

# 64-character hex key (required) - generate with: openssl rand -hex 32
SECRET_KEY=

# ==============================================================================
# BUILT-IN ADDONS
# ==============================================================================

# Enable built-in addons (recommended for TorBox Pro users)
AIOSTREAMS_BUILTIN_ADDONS=true

# ==============================================================================
# DEBRID SERVICES
# ==============================================================================

# TorBox API Key (get from TorBox dashboard)
DEFAULT_TORBOX_API_KEY=
# FORCED_TORBOX_API_KEY=  # Uncomment to force a specific key (hidden from users)

# Real-Debrid API Key
# DEFAULT_REALDEBRID_API_KEY=

# ==============================================================================
# JACKETT INTEGRATION
# ==============================================================================

# Jackett URL (use internal network URL: http://jackett:9117)
BUILTIN_JACKETT_URL=http://jackett:9117

# Jackett API Key (find in Jackett UI -> Configuration -> General -> API Key)
# BUILTIN_JACKETT_API_KEY=

# ==============================================================================
# AIOMETADATA (auto-configured via compose)
# ==============================================================================

# Hostname for AIOMetadata (compose maps to HOST_NAME internally)
# AIOMETADATA_HOST=aiometadata.fewa.app

# Redis URL (uses REDIS_HOST_SHARED via compose)
# REDIS_URL is set in compose via REDIS_HOST_SHARED

# TMDB API Key (get from https://www.themoviedb.org/settings/api)
# TMDB_API=

# TVDB API Key (get from https://thetvdb.com/)
# TVDB_API_KEY=

# Database (SQLite is default, no config needed)
# DATABASE_URI=sqlite://addon/data/db.sqlite

# Optional: Enable cache warming for faster first-load
# ENABLE_CACHE_WARMING=true

# ==============================================================================
# WARP PROXY (optional - enables IP rotation)
# ==============================================================================

# Point AIOStreams through WARP for IP rotation
# ADDON_PROXY=http://warp:1080

# MediaFlow Proxy password
# MEDIAFLOW_PASSWORD=your_proxy_password

# ==============================================================================
# LOGGING (optional)
# ==============================================================================
# ==============================================================================
# PROXY SERVICES (optional, enable with --profile proxy)
# ==============================================================================

# MediaFlow Proxy password
# MEDIAFLOW_PASSWORD=your_proxy_password

# MediaFlow host (used for Traefik routing)
# MEDIAFLOW_HOST=mediaflow.fewa.app

# ==============================================================================
# LOGGING (optional)
# ==============================================================================

# LOG_LEVEL=info
# LOG_FORMAT=text