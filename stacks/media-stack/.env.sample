# AIOMetadata Environment Variables
# Copy this to .env and fill in required values
#
# IMPORTANT: HTTPS is MANDATORY (Stremio only connects to https endpoints)

# ==============================================================================
# REQUIRED
# ==============================================================================

# Hostname for AIOMetadata (compose maps to HOST_NAME internally)
# AIOMETADATA_HOST=aiometadata.fewa.app

# Hostname for Decypharr
# DECYPHARR_HOST=decypharr.fewa.app

# Redis URL (uses REDIS_HOST_SHARED via compose)
# REDIS_URL is set in compose via REDIS_HOST_SHARED

# TMDB API Key (get from https://www.themoviedb.org/settings/api)
# TMDB_API=

# TVDB API Key (get from https://thetvdb.com/)
# TVDB_API_KEY=

# Database (SQLite is default, no config needed)
# DATABASE_URI=sqlite://addon/data/db.sqlite

# Optional: Enable cache warming for faster first-load
# ENABLE_CACHE_WARMING=true

# ==============================================================================
# DECYPHARR (Debrid Media Manager)
# ==============================================================================

# Torbox API Key (get from Torbox dashboard)
# TORBOX_API_KEY=

# Sonarr API Token (get from Sonarr -> Settings -> General -> Security -> API Key)
# SONARR_TOKEN=

# Radarr API Token (get from Radarr -> Settings -> General -> Security -> API Key)
# RADARR_TOKEN=

# ==============================================================================
# POSTER CACHE (auto-configured via compose)
# ==============================================================================

# Poster proxy prefix URL (compose maps automatically)
# POSTER_PROXY_PREFIX_URL=https://poster-cache.fewa.app

# Poster warmup URL (internal network)
# POSTER_WARMUP_URL=http://poster-cache:8888

# Poster warmup delay in milliseconds
# POSTER_WARMUP_DELAY_MS=50
