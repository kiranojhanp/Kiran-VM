PORTABASE_HOST=portabase.fewa.app
PORTABASE_TZ=UTC

# Generate with: openssl rand -hex 32
PORTABASE_PROJECT_SECRET=change-me-please-generate-a-secure-hex-token

PORTABASE_POSTGRES_DB=portabase
PORTABASE_POSTGRES_USER=portabase
PORTABASE_POSTGRES_PASSWORD=change-me

# Optional override. By default this is built from PORTABASE_HOST.
# PORTABASE_PROJECT_URL=https://portabase.fewa.app

# Agent settings
# Create an agent in Portabase dashboard and paste its Edge Key here.
PORTABASE_AGENT_EDGE_KEY=
PORTABASE_AGENT_TZ=UTC
PORTABASE_AGENT_POLLING=5
PORTABASE_AGENT_LOG=info
