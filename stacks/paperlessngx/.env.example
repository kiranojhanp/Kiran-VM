# Paperless-ngx Environment Variables
# Copy this to .env and fill in required values
# Deploy with: docker compose --env-file .env up -d

# ==============================================================================
# REQUIRED
# ==============================================================================

# Hostname (FQDN) for Paperless-ngx
# PAPERLESS_HOST=paperless.fewa.app

# Django secret key — generate with: openssl rand -hex 32
# Must be stable across restarts to preserve user sessions.
# PAPERLESS_SECRET_KEY=

# Database password (must match postgres_paperless_password in provision/secrets.yml)
# PAPERLESS_DB_PASSWORD=

# ==============================================================================
# OPTIONAL (defaults shown)
# ==============================================================================

# Timezone (default: UTC)
# TZ=UTC

# Shared Redis host (default: redis)
# SHARED_REDIS_HOST=redis

# Shared Postgres host (default: postgres)
# SHARED_POSTGRES_HOST=postgres

# Database name (default: paperless)
# PAPERLESS_DB_NAME=paperless

# Database user (default: paperless)
# PAPERLESS_DB_USER=paperless

# Shared Docker network (default: internal-network)
# SHARED_DOCKER_NETWORK=internal-network

# Shared infra network (default: infra_net)
# SHARED_INFRA_NETWORK=infra_net
