services:
  traefik:
    image: traefik:v3.6.10
    command:
      - --configFile=/etc/traefik/traefik.yml
    restart: unless-stopped
    init: true
    environment:
      CLOUDFLARE_DNS_API_TOKEN: ${CLOUDFLARE_API_TOKEN}
      CF_DNS_API_TOKEN: ${CLOUDFLARE_API_TOKEN}
      DOCKER_API_VERSION: ${DOCKER_API_VERSION}
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./traefik.yml:/etc/traefik/traefik.yml:ro
      - ./dynamic.yml:/etc/traefik/dynamic.yml:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - traefik_letsencrypt:/letsencrypt
    networks:
      - shared
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: 512m

  fewa-site:
    image: hashicorp/http-echo:1.0.0
    command:
      - -listen
      - :5678
      - -text
      - Welcome to {{ traefik_domain }}
    restart: unless-stopped
    init: true
    networks:
      - shared
    labels:
      traefik.enable: "true"
      traefik.docker.network: "{{ shared_docker_network }}"
      traefik.http.routers.root.rule: "Host(`{{ traefik_domain }}`)"
      traefik.http.routers.root.entrypoints: websecure
      traefik.http.routers.root.tls: "true"
      traefik.http.routers.root.tls.certresolver: cloudflare
      traefik.http.routers.root.middlewares: root-security-headers,compress
      traefik.http.middlewares.root-security-headers.headers.customFrameOptionsValue: SAMEORIGIN
      traefik.http.middlewares.root-security-headers.headers.contentTypeNosniff: "true"
      traefik.http.middlewares.root-security-headers.headers.referrerPolicy: strict-origin-when-cross-origin
      traefik.http.middlewares.root-security-headers.headers.stsSeconds: "31536000"
      traefik.http.middlewares.root-security-headers.headers.stsIncludeSubdomains: "true"
      traefik.http.middlewares.root-security-headers.headers.stsPreload: "true"
      traefik.http.middlewares.root-security-headers.headers.customResponseHeaders.Content-Security-Policy: "default-src 'self'"
      traefik.http.middlewares.compress.compress: "true"
      traefik.http.services.root.loadbalancer.server.port: "5678"
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: 64m

networks:
  shared:
    name: {{ shared_docker_network }}
    external: true

volumes:
  traefik_letsencrypt:
