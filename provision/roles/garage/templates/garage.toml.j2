metadata_dir = "/var/lib/garage/meta"
data_dir = "/var/lib/garage/data"

replication_factor = 1

rpc_bind_addr = "[::]:3901"
rpc_public_addr = "[::]:3901"
rpc_secret = "{{ garage_rpc_secret }}"

bootstrap_peers = []

[s3_api]
s3_region = "{{ garage_s3_region | default('us-east-1') }}"
api_bind_addr = "[::]:3900"
root_domain = ".s3.{{ garage_domain | default('localhost') }}"

[s3_web]
bind_addr = "[::]:3902"
root_domain = ".web.{{ garage_domain | default('localhost') }}"
index = "index.html"

[admin]
api_bind_addr = "[::]:3903"
admin_token = "{{ garage_admin_token }}"
metrics_token = "{{ garage_metrics_token }}"
