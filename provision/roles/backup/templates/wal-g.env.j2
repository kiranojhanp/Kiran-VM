# WAL-G configuration
# Sourced by all wal-g scripts and systemd units

WALG_S3_PREFIX=s3://{{ backup_wal_g_s3_bucket }}/{{ backup_wal_g_s3_prefix | default('') }}
AWS_ENDPOINT={{ backup_wal_g_aws_endpoint }}
AWS_S3_FORCE_PATH_STYLE={{ backup_wal_g_s3_force_path_style | default('true') }}
AWS_ACCESS_KEY_ID={{ backup_wal_g_aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ backup_wal_g_aws_secret_access_key }}
AWS_REGION={{ backup_wal_g_aws_region | default('auto') }}
WALG_PASSWORD={{ backup_wal_g_password }}

# Postgres connection (for WAL-G inside container)
POSTGRES_PASSWORD={{ shared_postgres_password }}

WALG_COMPRESSION_METHOD={{ backup_wal_g_compression_method | default('lz4') }}
WALG_DELTA_MAX_STEPS={{ backup_wal_g_delta_max_steps | default(6) }}
WALG_S3_STORAGE_CLASS=STANDARD

WALG_RETENTION_FULL={{ backup_wal_g_retention_full | default(4) }}
WALG_RETENTION_KEEP={{ backup_wal_g_retention_keep | default(4) }}
WALG_RETENTION_KEEP_WEEKLY={{ backup_wal_g_retention_keep_weekly | default(4) }}
WALG_RETENTION_KEEP_MONTHLY={{ backup_wal_g_retention_keep_monthly | default(6) }}
WALG_RETENTION_KEEP_YEARLY={{ backup_wal_g_retention_keep_yearly | default(1) }}

BACKUP_LOGS_DIR={{ backup_logs_dir | default('/var/log/kiran-backup') }}
