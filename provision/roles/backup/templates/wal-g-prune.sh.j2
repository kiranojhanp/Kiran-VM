#!/usr/bin/env bash
{% raw %}
set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/wal-g.env"

POSTGRES_CONTAINER="{{ postgres_container_name }}"

log() { echo "[$(date -Iseconds)] $*"; }
log_section() { echo ""; echo "========== $(date -Iseconds) WAL-G RETENTION PRUNE =========="; }

section() {
  log_section
  log "Applying retention policy via ${POSTGRES_CONTAINER}"
  log "Full=${WALG_RETENTION_FULL} weekly=${WALG_RETENTION_KEEP_WEEKLY} monthly=${WALG_RETENTION_KEEP_MONTHLY} yearly=${WALG_RETENTION_KEEP_YEARLY}"
}

section

log "Dry-run first"
docker exec "${POSTGRES_CONTAINER}" env \
  PGUSER=postgres \
  PGPASSWORD="${POSTGRES_PASSWORD}" \
  PGHOST=localhost \
  WALG_S3_PREFIX="${WALG_S3_PREFIX}" \
  WALG_PASSWORD="${WALG_PASSWORD}" \
  AWS_ENDPOINT="${AWS_ENDPOINT}" \
  AWS_S3_FORCE_PATH_STYLE="${AWS_S3_FORCE_PATH_STYLE:-true}" \
  AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID}" \
  AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY}" \
  AWS_REGION="${AWS_REGION}" \
  WALG_S3_STORAGE_CLASS=STANDARD \
  wal-g delete \
    --retain-full "${WALG_RETENTION_FULL}" \
    --retain-full-after-find \
    --keep-weekly "${WALG_RETENTION_KEEP_WEEKLY}" \
    --keep-monthly "${WALG_RETENTION_KEEP_MONTHLY}" \
    --keep-yearly "${WALG_RETENTION_KEEP_YEARLY}" \
    --dry-run

log "Applying changes"
docker exec "${POSTGRES_CONTAINER}" env \
  PGUSER=postgres \
  PGPASSWORD="${POSTGRES_PASSWORD}" \
  PGHOST=localhost \
  WALG_S3_PREFIX="${WALG_S3_PREFIX}" \
  WALG_PASSWORD="${WALG_PASSWORD}" \
  AWS_ENDPOINT="${AWS_ENDPOINT}" \
  AWS_S3_FORCE_PATH_STYLE="${AWS_S3_FORCE_PATH_STYLE:-true}" \
  AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID}" \
  AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY}" \
  AWS_REGION="${AWS_REGION}" \
  WALG_S3_STORAGE_CLASS=STANDARD \
  wal-g delete \
    --retain-full "${WALG_RETENTION_FULL}" \
    --retain-full-after-find \
    --keep-weekly "${WALG_RETENTION_KEEP_WEEKLY}" \
    --keep-monthly "${WALG_RETENTION_KEEP_MONTHLY}" \
    --keep-yearly "${WALG_RETENTION_KEEP_YEARLY}"

log "Retention prune completed"
{% endraw %}
