#!/usr/bin/env bash
set -euo pipefail

set -a
source "{{ backup_dir }}/scripts/backup.env"
set +a

timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
tmp_dir="{{ backup_postgres_dump_dir }}/.tmp-${timestamp}"
mkdir -p "${tmp_dir}"

IFS=',' read -r -a databases <<< "${BACKUP_SHARED_POSTGRES_DATABASES}"
for db in "${databases[@]}"; do
  clean_db="$(printf '%s' "${db}" | xargs)"
  if [[ -z "${clean_db}" ]]; then
    continue
  fi

  docker exec -e PGPASSWORD="${BACKUP_SHARED_POSTGRES_PASSWORD}" "${BACKUP_SHARED_POSTGRES_CONTAINER}" \
    pg_dump -h 127.0.0.1 -U "${BACKUP_SHARED_POSTGRES_USER}" -d "${clean_db}" -Fc \
    | gzip -9 > "${tmp_dir}/${clean_db}.${timestamp}.dump.gz"
done

find "{{ backup_postgres_dump_dir }}" -maxdepth 1 -type f -name '*.dump.gz' -mtime +7 -delete
mv "${tmp_dir}"/*.dump.gz "{{ backup_postgres_dump_dir }}/"
rmdir "${tmp_dir}"
