access-key-id: {{ garage_access_key_id }}
secret-access-key: {{ garage_secret_access_key }}

dbs:
  - path: {{ litestream_backup_data_path }}/{{ litestream_backup_db_path }}
    replicas:
      - url: s3://{{ litestream_backup_bucket }}/{{ litestream_backup_path }}
        endpoint: https://s3.fewa.app
        region: ap-southeast-1
        force-path-style: true
