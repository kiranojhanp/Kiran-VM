{% if postgres_replication_user is defined and postgres_replication_user %}
CREATE USER {{ postgres_replication_user }} WITH REPLICATION ENCRYPTED PASSWORD '{{ postgres_replication_password }}';
{% endif %}

{% if postgres_extensions is defined %}
{% for ext in postgres_extensions %}
CREATE EXTENSION IF NOT EXISTS {{ ext }};
{% endfor %}
{% endif %}

{% if postgres_databases_list is defined %}
{% for db_name in postgres_databases_list %}
CREATE USER {{ db_name }} WITH ENCRYPTED PASSWORD '{{ shared_postgres_password }}';
CREATE DATABASE {{ db_name }} WITH OWNER {{ db_name }};
GRANT ALL PRIVILEGES ON DATABASE {{ db_name }} TO {{ db_name }};
GRANT ALL ON SCHEMA public TO {{ db_name }};
ALTER DATABASE {{ db_name }} OWNER TO {{ db_name }};
{% endfor %}
{% endif %}

{% if postgres_users is defined %}
{% for user in postgres_users %}
CREATE USER {{ user.name }} WITH ENCRYPTED PASSWORD '{{ user.password }}'{% if user.superuser | default(false) %} SUPERUSER{% endif %};
GRANT ALL PRIVILEGES ON DATABASE {{ user.database | default('postgres') }} TO {{ user.name }};
{% endfor %}
{% endif %}

{% if postgres_databases is defined %}
{% for db in postgres_databases %}
CREATE DATABASE {{ db.name }}{% if db.owner %} WITH OWNER {{ db.owner }}{% endif %};
{% endfor %}
{% endif %}
