Port {{ ssh_port }}
PermitRootLogin no
PasswordAuthentication no
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys
# KbdInteractiveAuthentication replaces ChallengeResponseAuthentication (deprecated in OpenSSH 8.7+)
KbdInteractiveAuthentication no
UsePAM yes
X11Forwarding no
MaxAuthTries 3
MaxSessions 5
# ubuntu is removed from AllowUsers post-hardening; only deploy_user is permitted.
AllowUsers {{ deploy_user }}
PrintMotd no
AcceptEnv LANG LC_*
Subsystem sftp /usr/lib/openssh/sftp-server

# Idle session / brute-force mitigation
LoginGraceTime 30
ClientAliveInterval 300
ClientAliveCountMax 3
