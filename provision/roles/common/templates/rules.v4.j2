# /etc/iptables/rules.v4
# Managed by Ansible — do not edit manually.
#
# OCI Ubuntu instances require iptables rules for VNIC routing.
# This file preserves the OCI baseline and adds application rules on top.
# UFW is NOT used — it flushes iptables on reset, which breaks OCI networking.
#
# Applied by: netfilter-persistent (iptables-persistent) at boot
# Reload:     netfilter-persistent reload
#             — or —
#             iptables-restore < /etc/iptables/rules.v4

*filter
:INPUT DROP [0:0]
:FORWARD ACCEPT [0:0]
# Note: FORWARD is ACCEPT — Docker requires this to route container traffic.
# DOCKER-USER chain rules are defined below (before *filter COMMIT).
:OUTPUT ACCEPT [0:0]

# ── Loopback ────────────────────────────────────────────────────────────────
-A INPUT -i lo -j ACCEPT

# ── Established / Related ───────────────────────────────────────────────────
-A INPUT -m state --state RELATED,ESTABLISHED -j ACCEPT

# ── ICMP ────────────────────────────────────────────────────────────────────
# Required by OCI: Path MTU discovery (type 3 code 4) must be allowed
-A INPUT -p icmp --icmp-type 3 -j ACCEPT
-A INPUT -p icmp --icmp-type 8 -j ACCEPT

# ── SSH ─────────────────────────────────────────────────────────────────────
# Port 22: open on first run so Ansible can connect before hardening
# After common role runs, sshd moves to {{ ssh_port }} (2222)
# Set ssh_allow_port_22: false in group_vars/all.yml after confirming 2222 works.
{% if ssh_allow_port_22 | default(true) %}
-A INPUT -p tcp --dport 22 -j ACCEPT
{% endif %}
-A INPUT -p tcp --dport {{ ssh_port }} -j ACCEPT

# ── Web traffic ─────────────────────────────────────────────────────────────
-A INPUT -p tcp --dport 80 -j ACCEPT
-A INPUT -p tcp --dport 443 -j ACCEPT

# ── Explicit denies ─────────────────────────────────────────────────────────
# Komodo (only accessible via Traefik reverse proxy; core binds localhost)
-A INPUT -p tcp --dport {{ komodo_port }} -j DROP

# ── Default: DROP everything else (set by chain policy above) ──────────────

# ── Docker published ports hardening ────────────────────────────────────────
# DOCKER-USER is evaluated before Docker's own NAT rules.
# Allow established/related connections through.
-A DOCKER-USER -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN
# Allow loopback.
-A DOCKER-USER -s 127.0.0.0/8 -j RETURN
# Allow Docker bridge networks (172.16–172.31 range covers default Docker DHCP range).
-A DOCKER-USER -s 172.16.0.0/12 -j RETURN
# Allow infra network (existing infra_net bridge, gateway 172.19.0.1).
-A DOCKER-USER -s 172.19.0.0/16 -j RETURN
# Allow Traefik-published web traffic from anywhere (HTTPS terminates at Traefik).
-A DOCKER-USER -p tcp --dport 80 -j RETURN
-A DOCKER-USER -p tcp --dport 443 -j RETURN
# Drop everything else attempting to reach Docker-published ports.
-A DOCKER-USER -m conntrack --ctstate NEW -j DROP
-A DOCKER-USER -j RETURN

COMMIT

*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
COMMIT

*mangle
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
COMMIT
