# ── FerretDB ──────────────────────────────────────────────────────────────────
# FerretDB maps Postgres users to MongoDB auth. Komodo connects as this user.
FERRETDB_POSTGRES_PASSWORD={{ ferretdb_postgres_password }}
KOMODO_DATABASE_USERNAME=ferretdb
KOMODO_DATABASE_PASSWORD={{ ferretdb_postgres_password }}

# ── Komodo Core ───────────────────────────────────────────────────────────────
KOMODO_HOST=https://{{ komodo_subdomain }}
KOMODO_PORT={{ komodo_port }}
KOMODO_WEBHOOK_SECRET={{ komodo_webhook_secret }}
KOMODO_JWT_SECRET={{ komodo_jwt_secret }}
KOMODO_LOG_LEVEL={{ komodo_log_level }}
KOMODO_INIT_ADMIN_USERNAME={{ komodo_init_admin_username }}
KOMODO_INIT_ADMIN_PASSWORD={{ komodo_password }}
KOMODO_RESOURCE_POLL_INTERVAL={{ komodo_resource_poll_interval }}
# Periphery agent public key — Core uses this to authenticate inbound Periphery connections.
KOMODO_PERIPHERY_PUBLIC_KEYS={{ komodo_periphery_public_keys | default('') }}

# ── Komodo Periphery (outbound mode) ─────────────────────────────────────────
# Core PKI public key — set via komodo_core_public_keys in secrets.yml after first deploy.
# Periphery authenticates to Core using this key.
# Get the Core Public Key from Komodo UI: Settings → Core Public Key (starts with MCow...).
PERIPHERY_CORE_PUBLIC_KEYS={{ komodo_core_public_keys | default('') }}
# Address of Komodo Core. Periphery initiates connection to this address.
PERIPHERY_CORE_ADDRESS=wss://{{ komodo_subdomain }}
# Server name this Periphery agent should connect as.
PERIPHERY_CONNECT_AS={{ komodo_first_server_name }}
# Onboarding key from Komodo UI: Settings → Onboarding.
PERIPHERY_ONBOARDING_KEY={{ komodo_onboarding_key }}
