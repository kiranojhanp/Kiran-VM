---
# Managed by Ansible — do not edit by hand
# Komodo stack: postgres-documentdb → ferretdb → komodo-core + komodo-periphery

networks:
  komodo-net:
    driver: bridge
  shared-proxy-net:
    external: true
    name: "{{ shared_docker_network }}"

volumes:
  ferretdb-pg-data:

services:

  # ── FerretDB's dedicated patched Postgres ────────────────────────────────
  ferretdb-postgres:
    container_name: komodo-ferretdb-postgres-1
    image: "{{ ferretdb_pg_image }}"
    restart: unless-stopped
    env_file: .env
    environment:
      POSTGRES_USER: ferretdb
      POSTGRES_PASSWORD: "${FERRETDB_POSTGRES_PASSWORD}"
      POSTGRES_DB: postgres
    volumes:
      - ferretdb-pg-data:/var/lib/postgresql/data
    networks:
      - komodo-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ferretdb"]
      interval: 10s
      timeout: 5s
      retries: 5
    mem_limit: 1g

  # ── FerretDB (MongoDB wire protocol → Postgres) ───────────────────────────
  ferretdb:
    image: "{{ ferretdb_image }}"
    restart: unless-stopped
    environment:
      FERRETDB_POSTGRESQL_URL: "postgres://ferretdb:${FERRETDB_POSTGRES_PASSWORD}@ferretdb-postgres:5432/postgres"
    networks:
      - komodo-net
    depends_on:
      ferretdb-postgres:
        condition: service_healthy
    mem_limit: 512m

  # ── Komodo Core ───────────────────────────────────────────────────────────
  komodo:
    image: "{{ komodo_image }}"
    restart: unless-stopped
    env_file: .env
    environment:
      KOMODO_LOCAL_AUTH: "true"
      KOMODO_DATABASE_ADDRESS: "ferretdb:27017"
      KOMODO_FIRST_SERVER: "http://periphery:8120"
    ports:
      - "127.0.0.1:{{ komodo_port }}:{{ komodo_port }}"
    labels:
      traefik.enable: "true"
      traefik.docker.network: "{{ shared_docker_network }}"
      traefik.http.routers.komodo.rule: "Host(`{{ komodo_subdomain }}`)"
      traefik.http.routers.komodo.entrypoints: websecure
      traefik.http.routers.komodo.tls: "true"
      traefik.http.routers.komodo.tls.certresolver: cloudflare
      traefik.http.routers.komodo.middlewares: security-headers,compress
      traefik.http.middlewares.security-headers.headers.customFrameOptionsValue: SAMEORIGIN
      traefik.http.middlewares.security-headers.headers.contentTypeNosniff: "true"
      traefik.http.middlewares.security-headers.headers.referrerPolicy: strict-origin-when-cross-origin
      traefik.http.middlewares.security-headers.headers.stsSeconds: "31536000"
      traefik.http.middlewares.security-headers.headers.stsIncludeSubdomains: "true"
      traefik.http.middlewares.security-headers.headers.stsPreload: "true"
      traefik.http.middlewares.security-headers.headers.customResponseHeaders.Content-Security-Policy: "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' wss:; frame-ancestors 'self'"
      traefik.http.middlewares.compress.compress: "true"
      traefik.http.services.komodo.loadbalancer.server.port: "{{ komodo_port }}"
    volumes:
      - "{{ komodo_dir }}/data:/etc/komodo"
    networks:
      komodo-net:
      shared-proxy-net:
        aliases:
          - komodo
    depends_on:
      ferretdb:
        condition: service_started
    mem_limit: 1g

  # ── Komodo Periphery (agent — manages Docker on this host) ────────────────
  periphery:
    image: "{{ komodo_periphery_image }}"
    restart: unless-stopped
    labels:
      # Prevent Komodo from managing/stopping its own agent container.
      komodo.skip: "true"
    env_file: .env
    environment:
      PERIPHERY_ROOT_DIRECTORY: "{{ komodo_dir }}/periphery"
      PERIPHERY_INCLUDE_DISK_MOUNTS: "/,/mnt,/opt"
      PERIPHERY_SSL_ENABLED: "false"
      # Base path prefix for bind mounts in Komodo-managed stacks (e.g. $DOCKER_DATA/nocodb/data).
      DOCKER_DATA: "/opt"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /proc:/proc
      - "{{ komodo_dir }}/periphery:/etc/komodo"
    networks:
      - komodo-net
    mem_limit: 256m
