# Copy this to hosts.ini and fill in your server details.
# hosts.ini is gitignored — never commit it.
#
#   cp provision/inventory/hosts.ini.example provision/inventory/hosts.ini

[server]
YOUR_SERVER_IP ansible_user=deploy ansible_ssh_private_key_file=~/.ssh/id_ed25519 ansible_ssh_port=2222

[server:vars]
ansible_ssh_common_args='-o StrictHostKeyChecking=accept-new -o ServerAliveInterval=30'
