---
# Managed by Ansible — do not edit by hand
# Databasus — database backup manager

networks:
  infra_net:
    external: true
  komodo_komodo-net:
    external: true

services:
  databasus:
    image: "{{ host.data.databasus_image }}"
    restart: unless-stopped
    env_file: .env
    ports:
      - "127.0.0.1:{{ host.data.databasus_port }}:4005"
    volumes:
      - "{{ host.data.databasus_dir }}/data:/databasus-data"
    networks:
      - infra_net
      - komodo_komodo-net
