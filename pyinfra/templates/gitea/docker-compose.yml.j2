---
# Managed by Ansible — do not edit by hand
# Gitea (rootless) — self-hosted git forge

networks:
  # Join shared infra network for Postgres access
  infra_net:
    external: true

services:
  gitea:
    image: "{{ host.data.gitea_image }}"
    restart: unless-stopped
    # Rootless image runs as uid 1000 — data dirs must be owned by 1000:1000.
    user: "1000:1000"
    env_file: .env
    ports:
      - "127.0.0.1:{{ host.data.gitea_http_port }}:3000"
      - "0.0.0.0:{{ host.data.gitea_ssh_port }}:2222"
    volumes:
      - "{{ host.data.gitea_dir }}/data:/var/lib/gitea"
      - "{{ host.data.gitea_dir }}/config:/etc/gitea"
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
    networks:
      - infra_net
    mem_limit: 512m
