# ── FerretDB ──────────────────────────────────────────────────────────────────
# FerretDB maps Postgres users to MongoDB auth. Komodo connects as this user.
FERRETDB_POSTGRES_PASSWORD={{ host.data.ferretdb_postgres_password }}
KOMODO_DATABASE_USERNAME=ferretdb
KOMODO_DATABASE_PASSWORD={{ host.data.ferretdb_postgres_password }}

# ── Komodo Core ───────────────────────────────────────────────────────────────
KOMODO_HOST=https://{{ host.data.komodo_subdomain }}
KOMODO_PORT={{ host.data.komodo_port }}
KOMODO_PASSKEY={{ host.data.komodo_passkey }}
KOMODO_WEBHOOK_SECRET={{ host.data.komodo_webhook_secret }}
KOMODO_JWT_SECRET={{ host.data.komodo_jwt_secret }}
KOMODO_LOG_LEVEL={{ host.data.komodo_log_level }}
KOMODO_INIT_ADMIN_USERNAME={{ host.data.komodo_init_admin_username }}
KOMODO_INIT_ADMIN_PASSWORD={{ host.data.komodo_password }}

# ── Komodo Periphery ──────────────────────────────────────────────────────────
# Passkeys must match KOMODO_PASSKEY so the core can authenticate to periphery.
PERIPHERY_PASSKEYS={{ host.data.komodo_passkey }}
